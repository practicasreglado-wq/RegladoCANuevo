# Configuración SMTP del formulario de contacto
# Copiar este archivo a `.env` y rellenar con valores reales (NO commitear .env).

# Servidor SMTP de Reglado (SendGrid, Mailgun, ZeptoMail, SMTP propio…)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=changeme

# From: ha de coincidir con un dominio con SPF/DKIM/DMARC válidos
SMTP_FROM=web@regladoconsultores.com

# Destinatario de las consultas
CONTACT_TO=info@regladoconsultores.com

# Origen permitido para CORS (sin barra final). Vacío = mismo dominio.
ALLOWED_ORIGIN=https://regladoconsultores.com
