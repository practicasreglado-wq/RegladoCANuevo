# Archivos de dependencias (NO se deben subir, se instalan con npm/composer)
node_modules/
vendor/

# Carpeta de construcción (resultado final de la web)
dist/
dist-ssr/
*.local

# Logs y archivos temporales de ejecución
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Archivos de entorno (pueden contener contraseñas sensibles)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Archivos del sistema operativo y editores
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Si usas XAMPP y se generan archivos temporales
php_error_log
